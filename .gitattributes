# Normalize line endings in the repo (store LF). Checked out native on Windows.
* text=auto

# These run on a Linux server — MUST stay LF (CRLF breaks the shebang / parsing).
*.sh            text eol=lf
*.py            text eol=lf
*.conf          text eol=lf
*.service       text eol=lf
*.env.example   text eol=lf

# Binary assets — never touch.
*.png binary
*.mp3 binary
